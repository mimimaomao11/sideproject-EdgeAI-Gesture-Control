# ===========================
# Project Specific
# ===========================

# MediaPipe model (大檔案，不推送到 GitHub)
# 使用者應透過 download_model.py 自行下載
hand_landmarker.task

# Personal test videos and images
# 避免個人測試資料被推送
test_video*.mp4
test_video*.avi
my_test*.jpg
my_test*.png
personal_*.jpg
personal_*.png
demo_recording*.mp4

# Temporary files
*.tmp
*.temp

# Log files
*.log
logs/

# ===========================
# Development & Testing
# ===========================

# Test output files
test_output/
test_results/
output/

# Debug files
debug_*.py
diagnose_*.py

# Experimental scripts
experiment_*.py
temp_*.py

# ===========================
# Documentation Handling
# ===========================
# Ignore everything in docs by default
docs/*

# But keep these specific files
!docs/SPEC.md
!docs/task.md


# ===========================
# Misc
# ===========================

# Backup files
*.bak
*.backup
*~

# Archive files (if used for backups)
*.zip
*.tar.gz
*.rar
*.7z
